:: Story Stylesheet {"position":"0,0","size":"100,100"}
/* Load fonts here (no <link> tags needed) */
@import url('https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0,1&family=Spectral:wght@400,600&display=swap'),

:root{
  --paper:#f7f6f1,
  --ink:#0a0a0a,
  --soot:#222,
  --line:#111,
  --ash:#666,
  --accent:#7a7a7a,
  --frame:#0a0a0a,
  --shadow: rgba(0,0,0,.35),
  --ring:#bdbdbd,
  --max: 72ch,
}

/* Page */
html,body{height:100%,margin:0,background:var(--ink),color:var(--paper),}

/* Background texture */
#story{
  min-height:100%,
  display:flex,flex-direction:column,justify-content:center,align-items:center,
  padding:2rem .75rem,
  background:
    radial-gradient(1200px 800px at 20% 10%, rgba(255,255,255,.05), transparent 60%),
    radial-gradient(1000px 600px at 80% 90%, rgba(255,255,255,.04), transparent 60%),
    repeating-linear-gradient(0deg, rgba(0,0,0,.02) 0 2px, transparent 2px 4px),
}

/* Scene frame */
#scene{
  width:min(95vw,640px),
  filter: grayscale(100%) contrast(105%),
  border:6px solid var(--frame),
  outline:10px double var(--ink),
  box-shadow:0 0 0 6px var(--paper) inset, 0 12px 28px var(--shadow),
  margin-bottom:1.5rem,
  background:#fff,
  display:block,
}

/* Passage body panel */
#passages{
  max-width:var(--max),
  background:var(--paper),
  color:var(--line),
  font-family:"Spectral", serif,
  font-size:1.15rem,
  line-height:1.6,
  padding:1.75rem 2.25rem,
  border:4px solid var(--line),
  outline:8px solid var(--ink),
  box-shadow:0 10px 24px var(--shadow),
}

/* Headings */
#passages h1,#passages h2,#passages h3{
  font-family:"IM Fell English", serif,
  color:var(--line),
  margin-top:0,
  letter-spacing:.02em,
  text-transform:uppercase,
}

/* Emphasis */
#passages strong{color:var(--ink),}
#passages em{color:var(--ash),}

/* Quotes */
#passages blockquote{
  margin:0 0 1rem 0,
  padding-left:1rem,
  border-left:4px solid var(--ink),
  color:var(--line),
}

/* Links */
#passages a.link-internal{
  color:var(--ink),
  text-decoration:underline,
  text-decoration-thickness:2px,
  text-underline-offset:2px,
}
#passages a.link-internal:hover{
  color:var(--soot),
  text-decoration-style:dotted,
}

/* Principle scrolls */
.principle-scroll{
  border:2px solid var(--line),
  background:#faf7f0,
  padding:1rem 1.25rem,
  margin:1rem 0 1.25rem,
  box-shadow:0 2px 4px var(--shadow),
  font-family:"IM Fell English", serif,
}

/* A11y + motion */
:focus-visible { outline: 2px solid var(--ring), outline-offset: 2px, }
@media (prefers-reduced-motion: reduce) { * { transition: none !important, animation: none !important, } }

@media(max-width:600px){
  #scene{width:98vw}
  #passages{padding:1.25rem,font-size:1.05rem}
}

/* Principle HUD (inline, under scene image) */
/* Principle HUD (inline, under scene image) */
.principle-hud-inline{
  position:static,
  background:#faf7f0,
  color:var(--line),
  border:1px solid var(--line),
  border-radius:6px,
  padding:.5rem .75rem,
  box-shadow:none,
  max-width:100%,
  margin:.35rem 0 .75rem 0,
  line-height:1.25,
}
.principle-hud-inline *{margin:0,padding:0,line-height:1.2}
.principle-hud-inline strong{display:block,font-weight:600,margin:0 0 .15rem 0}
.principle-hud-inline table{border-collapse:collapse,width:auto}
.principle-hud-inline td{padding:0 .5rem .1rem 0,vertical-align:top}
.principle-hud-inline td.k{opacity:.9,min-width:120px}
.principle-hud-inline .k{opacity:.9,min-width:100px}
.principle-hud-inline .v{opacity:1,font-weight:600}


